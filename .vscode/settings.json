{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "workbench.tree.indent": 15,
  "editor.formatOnSave": true,
  "editor.trimAutoWhitespace": true,
  "files.associations": {
    "*.html": "liquid"
  },
  "[liquid]": {
    "editor.formatOnSave": false
  }
}
